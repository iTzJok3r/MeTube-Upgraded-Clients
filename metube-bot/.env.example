# Telegram bot token from @BotFather
BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=

# MeTube backend URL (trailing slash required)
METUBE_URL=http://localhost:8081/

# Optional: set to enable webhook mode instead of polling
# BOT_WEBHOOK_URL=https://your-domain.com/bot-webhook
# BOT_WEBHOOK_PORT=3000
# BOT_WEBHOOK_SECRET=random-secret-string
